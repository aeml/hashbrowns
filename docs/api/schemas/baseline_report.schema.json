{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeml.github.io/hashbrowns/schemas/baseline_report.schema.json",
  "title": "hashbrowns baseline comparison report",
  "type": "object",
  "required": [
    "baseline_path",
    "scope",
    "threshold_pct",
    "noise_floor_pct",
    "strict_profile_intent",
    "exit_code",
    "metadata",
    "comparison",
    "per_operation_guard"
  ],
  "properties": {
    "baseline_path": {"type": "string"},
    "scope": {"type": "string", "enum": ["mean", "p95", "ci_high", "any"]},
    "threshold_pct": {"type": "number"},
    "noise_floor_pct": {"type": "number"},
    "strict_profile_intent": {"type": "boolean"},
    "exit_code": {"type": "integer", "enum": [0, 2, 4, 5]},
    "metadata": {
      "type": "object",
      "required": ["ok", "errors", "warnings"],
      "properties": {
        "ok": {"type": "boolean"},
        "errors": {"type": "array", "items": {"type": "string"}},
        "warnings": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "comparison": {
      "type": "object",
      "required": ["all_ok", "decision_basis", "entries"],
      "properties": {
        "all_ok": {"type": "boolean"},
        "decision_basis": {"type": "string", "enum": ["mean", "p95", "ci_high", "any"]},
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "structure",
              "insert_delta_pct",
              "search_delta_pct",
              "remove_delta_pct",
              "insert_ok",
              "search_ok",
              "remove_ok",
              "insert_basis",
              "search_basis",
              "remove_basis"
            ],
            "properties": {
              "structure": {"type": "string"},
              "insert_delta_pct": {"type": "number"},
              "search_delta_pct": {"type": "number"},
              "remove_delta_pct": {"type": "number"},
              "insert_ok": {"type": "boolean"},
              "search_ok": {"type": "boolean"},
              "remove_ok": {"type": "boolean"},
              "insert_basis": {"type": "string"},
              "search_basis": {"type": "string"},
              "remove_basis": {"type": "string"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "per_operation_guard": {
      "type": "object",
      "required": ["ok", "tolerances_pct", "entries", "failures"],
      "properties": {
        "ok": {"type": "boolean"},
        "tolerances_pct": {
          "type": "object",
          "required": ["insert", "search", "remove"],
          "properties": {
            "insert": {"type": "number"},
            "search": {"type": "number"},
            "remove": {"type": "number"}
          },
          "additionalProperties": false
        },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["structure", "insert", "search", "remove"],
            "properties": {
              "structure": {"type": "string"},
              "insert": {
                "type": "object",
                "required": ["baseline_value", "current_value", "delta_pct", "threshold_pct", "ok"],
                "properties": {
                  "baseline_value": {"type": "number"},
                  "current_value": {"type": "number"},
                  "delta_pct": {"type": "number"},
                  "threshold_pct": {"type": "number"},
                  "ok": {"type": "boolean"}
                },
                "additionalProperties": false
              },
              "search": {
                "type": "object",
                "required": ["baseline_value", "current_value", "delta_pct", "threshold_pct", "ok"],
                "properties": {
                  "baseline_value": {"type": "number"},
                  "current_value": {"type": "number"},
                  "delta_pct": {"type": "number"},
                  "threshold_pct": {"type": "number"},
                  "ok": {"type": "boolean"}
                },
                "additionalProperties": false
              },
              "remove": {
                "type": "object",
                "required": ["baseline_value", "current_value", "delta_pct", "threshold_pct", "ok"],
                "properties": {
                  "baseline_value": {"type": "number"},
                  "current_value": {"type": "number"},
                  "delta_pct": {"type": "number"},
                  "threshold_pct": {"type": "number"},
                  "ok": {"type": "boolean"}
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "failures": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
